rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    
    // Helper function to check if user is employee
    function isEmployee() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "employee";
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read all user documents
      allow read: if isAdmin();
      // Admins can update user roles
      allow update: if isAdmin();
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      // Anyone can create a booking (for public booking form)
      allow create: if true;
      
      // Users can read bookings if they are:
      // - Admin (can see all)
      // - The client who created it
      // - The employee it's assigned to
      allow read: if request.auth != null &&
        (isAdmin() ||
         resource.data.clientId == request.auth.uid ||
         resource.data.assignedTo == request.auth.uid);
      
      // Users can update bookings if they are:
      // - Admin (can update any)
      // - Employee assigned to it (can update status)
      allow update: if request.auth != null &&
        (isAdmin() ||
         resource.data.assignedTo == request.auth.uid);
      
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }
    
    // Portfolio collection
    match /portfolio/{itemId} {
      // Anyone can read portfolio (public showcase)
      allow read: if true;
      // Only admins can create, update, or delete portfolio items
      allow write: if isAdmin();
    }
    
    // Assignments collection (optional - for tracking project assignments)
    match /assignments/{assignmentId} {
      // Only admins can manage assignments
      allow read, write: if isAdmin();
    }
  }
}
